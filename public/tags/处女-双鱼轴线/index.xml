    <item>
      <title>机器人和艺伎 02</title>
      <link>http://localhost:59898/posts/2026/03/%E6%9C%BA%E5%99%A8%E4%BA%BA%E5%92%8C%E8%89%BA%E4%BC%8E-02/</link>
